# =============================================================================
# Supabase (Cloud) — チームで 1 つの共有プロジェクトを使う
# =============================================================================
# 取得先: https://supabase.com/dashboard
#   Project Settings → API ページで Project URL / anon key / service_role key を確認
#
# ⚠️ このファイルはサンプルです。実際の値は .env に入れ、絶対にコミットしないでください。
# 特に SUPABASE_SERVICE_ROLE_KEY は RLS をバイパスする強力なキーなので、サーバー側でのみ使用します。

# --- サーバー (Express) が使う変数 ---
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=replace_with_anon_key_from_dashboard
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key_from_dashboard

# --- API サーバーのポート（任意）---
# 既定 3000。他アプリと衝突するときだけ指定。指定したら VITE_API_URL も合わせること。
# API_PORT=3010

# --- Security / Auth ---
# Comma-separated allowed browser origins for API requests.
# Defaults to local Vite origins when omitted.
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Base URL used inside password reset links.
# PASSWORD_RESET_BASE_URL=http://localhost:5173

# Optional webhook that receives {"email":"...", "resetUrl":"..."} and sends the email.
# PASSWORD_RESET_WEBHOOK_URL=
# PASSWORD_RESET_WEBHOOK_SECRET=

# Development only: set true to print reset links to the server console when no webhook is configured.
# LOG_PASSWORD_RESET_LINKS=true

# --- フロントエンド (Vite) が使う変数 ---
# VITE_ プレフィックス必須。SUPABASE_* と同じ値で OK（フロントには service_role は渡さない）。
VITE_API_URL=http://localhost:3000
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=replace_with_anon_key_from_dashboard

# =============================================================================
# （任意）ローカル Supabase を使いたい人向け
# =============================================================================
# 通常は Cloud を使うため不要です。ローカル開発を試したい場合のみ
# README の「付録: ローカル Supabase」を参照してください。
# その場合の値（supabase status の出力から取得）:
#   SUPABASE_URL=http://127.0.0.1:55401
#   VITE_SUPABASE_URL=http://127.0.0.1:55401
